{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "urn:document-builder:layout:1",
    "title": "Document Builder canonical layout schema v1",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "schemaVersion",
        "capabilities",
        "document",
        "dataSource",
        "header",
        "sections",
        "footer"
    ],
    "properties": {
        "schemaVersion": {"const": 1},
        "capabilities": {
            "type": "array",
            "uniqueItems": true,
            "items": {"enum": ["layout.flow"]}
        },
        "document": {"$ref": "#/$defs/document"},
        "dataSource": {"$ref": "#/$defs/noSourceDescriptor"},
        "header": {"$ref": "#/$defs/emptyNodeSequence"},
        "sections": {
            "type": "array",
            "maxItems": 250,
            "items": {"$ref": "#/$defs/flowSection"}
        },
        "footer": {"$ref": "#/$defs/emptyNodeSequence"}
    },
    "$defs": {
        "stableId": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_-]{0,63}$"
        },
        "nodeType": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]{0,63}$"
        },
        "node": {
            "type": "object",
            "description": "Base properties for a registered node. Concrete node schemas must set unevaluatedProperties to false.",
            "required": ["id", "type"],
            "properties": {
                "id": {"$ref": "#/$defs/stableId"},
                "type": {"$ref": "#/$defs/nodeType"}
            }
        },
        "emptyNodeSequence": {
            "type": "array",
            "maxItems": 0
        },
        "millimetres": {
            "type": "object",
            "additionalProperties": false,
            "required": ["value", "unit"],
            "properties": {
                "value": {"type": "number", "minimum": 0, "maximum": 2000},
                "unit": {"const": "mm"}
            }
        },
        "points": {
            "type": "object",
            "additionalProperties": false,
            "required": ["value", "unit"],
            "properties": {
                "value": {"type": "number", "minimum": 0, "maximum": 512},
                "unit": {"const": "pt"}
            }
        },
        "percent": {
            "type": "object",
            "additionalProperties": false,
            "required": ["value", "unit"],
            "properties": {
                "value": {"type": "number", "minimum": 0, "maximum": 100},
                "unit": {"const": "percent"}
            }
        },
        "gridSpan": {
            "type": "object",
            "additionalProperties": false,
            "required": ["value", "unit"],
            "properties": {
                "value": {"type": "integer", "minimum": 1, "maximum": 24},
                "unit": {"const": "gridSpan"}
            }
        },
        "measurement": {
            "oneOf": [
                {"$ref": "#/$defs/millimetres"},
                {"$ref": "#/$defs/points"},
                {"$ref": "#/$defs/percent"},
                {"$ref": "#/$defs/gridSpan"}
            ]
        },
        "boxEdges": {
            "type": "object",
            "additionalProperties": false,
            "required": ["top", "right", "bottom", "left"],
            "properties": {
                "top": {"$ref": "#/$defs/millimetres"},
                "right": {"$ref": "#/$defs/millimetres"},
                "bottom": {"$ref": "#/$defs/millimetres"},
                "left": {"$ref": "#/$defs/millimetres"}
            }
        },
        "color": {
            "type": "string",
            "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "border": {
            "type": "object",
            "additionalProperties": false,
            "required": ["width", "style", "color"],
            "properties": {
                "width": {"$ref": "#/$defs/points"},
                "style": {"enum": ["none", "solid", "dashed", "dotted", "double"]},
                "color": {"$ref": "#/$defs/color"}
            }
        },
        "commonStyle": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "margin": {"$ref": "#/$defs/boxEdges"},
                "padding": {"$ref": "#/$defs/boxEdges"},
                "backgroundColor": {"$ref": "#/$defs/color"},
                "border": {"$ref": "#/$defs/border"},
                "opacity": {"type": "number", "minimum": 0, "maximum": 1},
                "horizontalAlignment": {"enum": ["start", "center", "end", "stretch"]},
                "verticalAlignment": {"enum": ["start", "center", "end"]},
                "width": {"oneOf": [{"$ref": "#/$defs/millimetres"}, {"$ref": "#/$defs/percent"}]},
                "height": {"oneOf": [{"$ref": "#/$defs/millimetres"}, {"$ref": "#/$defs/percent"}]},
                "color": {"$ref": "#/$defs/color"},
                "fontFamily": {"type": "string", "minLength": 1, "maxLength": 100, "pattern": "^[A-Za-z][A-Za-z0-9 ._-]*$"},
                "fontSize": {"$ref": "#/$defs/points"},
                "fontWeight": {"enum": ["normal", "bold", "100", "200", "300", "400", "500", "600", "700", "800", "900"]},
                "fontStyle": {"enum": ["normal", "italic"]},
                "textDecoration": {"enum": ["none", "underline"]},
                "lineHeight": {"type": "number", "minimum": 0.5, "maximum": 5},
                "letterSpacing": {"type": "object", "additionalProperties": false, "required": ["value", "unit"], "properties": {"value": {"type": "number", "minimum": -20, "maximum": 100}, "unit": {"const": "pt"}}},
                "textTransform": {"enum": ["none", "uppercase", "lowercase", "capitalize"]}
            }
        },
        "inlineText": {
            "type": "object", "additionalProperties": false,
            "required": ["type", "text", "marks"],
            "properties": {
                "type": {"const": "text"},
                "text": {"type": "string", "maxLength": 10000},
                "marks": {"type": "array", "uniqueItems": true, "items": {"enum": ["bold", "italic", "underline"]}},
                "color": {"$ref": "#/$defs/color"}
            }
        },
        "inlineBreak": {
            "type": "object", "additionalProperties": false,
            "required": ["type"], "properties": {"type": {"const": "break"}}
        },
        "inlineVariable": {
            "type": "object", "additionalProperties": false,
            "required": ["type", "tokenId", "label", "identity", "presentation"],
            "properties": {
                "type": {"const": "variable"},
                "tokenId": {"$ref": "#/$defs/stableId"},
                "label": {"type": "string", "minLength": 1, "maxLength": 100},
                "identity": {"$ref": "#/$defs/scalarVariableIdentity"},
                "presentation": {"$ref": "#/$defs/variablePresentation"}
            }
        },
        "variableFormat": {
            "type": "object", "additionalProperties": false,
            "required": ["type", "decimals", "dateStyle", "timeStyle", "currency", "trueLabel", "falseLabel", "separator", "trim", "case", "prefix", "suffix", "fallback"],
            "properties": {
                "type": {"enum": ["auto", "date", "datetime", "number", "currency", "boolean", "enum", "multiValue"]},
                "decimals": {"type": "integer", "minimum": 0, "maximum": 6},
                "dateStyle": {"enum": ["short", "medium", "long"]},
                "timeStyle": {"enum": ["short", "medium"]},
                "currency": {"type": ["string", "null"], "pattern": "^[A-Z]{3}$"},
                "trueLabel": {"type": ["string", "null"], "maxLength": 100},
                "falseLabel": {"type": ["string", "null"], "maxLength": 100},
                "separator": {"type": "string", "minLength": 1, "maxLength": 10},
                "trim": {"type": "boolean"},
                "case": {"enum": ["none", "upper", "lower", "title"]},
                "prefix": {"type": "string", "maxLength": 100},
                "suffix": {"type": "string", "maxLength": 100},
                "fallback": {"type": ["string", "null"], "maxLength": 200}
            }
        },
        "variablePresentation": {
            "type": "object", "additionalProperties": false,
            "required": ["format", "missing"],
            "properties": {
                "format": {"$ref": "#/$defs/variableFormat"},
                "missing": {"enum": ["empty", "fallback", "hideElement", "hideRow", "hideSection", "warning", "required"]}
            },
            "allOf": [{
                "if": {"properties": {"missing": {"const": "fallback"}}},
                "then": {"properties": {"format": {"properties": {"fallback": {"type": "string"}}}}}
            }]
        },
        "variablePath": {
            "type": "array", "minItems": 1, "maxItems": 4,
            "items": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_]{0,99}$"}
        },
        "directEntityVariableIdentity": {
            "type": "object", "additionalProperties": false,
            "required": ["source", "type", "entityType", "path"],
            "properties": {
                "source": {"const": "entity"},
                "type": {"const": "direct"},
                "entityType": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9]{0,99}$"},
                "path": {"type": "array", "minItems": 1, "maxItems": 1, "items": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_]{0,99}$"}}
            }
        },
        "relatedEntityVariableIdentity": {
            "type": "object", "additionalProperties": false,
            "required": ["source", "type", "entityType", "path"],
            "properties": {
                "source": {"const": "entity"},
                "type": {"const": "related"},
                "entityType": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9]{0,99}$"},
                "path": {"type": "array", "minItems": 2, "maxItems": 4, "items": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_]{0,99}$"}}
            }
        },
        "collectionVariableIdentity": {
            "type": "object", "additionalProperties": false,
            "required": ["source", "type", "entityType", "path"],
            "properties": {
                "source": {"const": "entity"},
                "type": {"const": "collection"},
                "entityType": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9]{0,99}$"},
                "path": {"$ref": "#/$defs/variablePath"}
            }
        },
        "systemVariableIdentity": {
            "type": "object", "additionalProperties": false,
            "required": ["source", "type", "path"],
            "properties": {
                "source": {"const": "system"}, "type": {"const": "system"},
                "path": {"type": "array", "minItems": 1, "maxItems": 1, "items": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_]{0,99}$"}}
            }
        },
        "spreadsheetVariableIdentity": {
            "type": "object", "additionalProperties": false,
            "required": ["source", "type", "path"],
            "properties": {
                "source": {"const": "spreadsheet"}, "type": {"const": "spreadsheet"},
                "path": {"type": "array", "minItems": 1, "maxItems": 1, "items": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_]{0,99}$"}}
            }
        },
        "scalarVariableIdentity": {
            "oneOf": [
                {"$ref": "#/$defs/directEntityVariableIdentity"},
                {"$ref": "#/$defs/relatedEntityVariableIdentity"},
                {"$ref": "#/$defs/systemVariableIdentity"},
                {"$ref": "#/$defs/spreadsheetVariableIdentity"}
            ]
        },
        "variableIdentity": {
            "oneOf": [
                {"$ref": "#/$defs/scalarVariableIdentity"},
                {"$ref": "#/$defs/collectionVariableIdentity"}
            ]
        },
        "conditionRule": {
            "type": "object", "additionalProperties": false,
            "required": ["identity", "valueType", "operator", "operand"],
            "properties": {
                "identity": {"$ref": "#/$defs/scalarVariableIdentity"},
                "valueType": {"enum": ["text", "date", "datetime", "number", "currency", "boolean", "enum", "multiValue"]},
                "operator": {"enum": ["exists", "missing", "equals", "notEquals", "contains", "startsWith", "greaterThan", "greaterOrEqual", "lessThan", "lessOrEqual", "isTrue", "isFalse"]},
                "operand": {"type": ["string", "number", "boolean", "null"], "maxLength": 1000}
            }
        },
        "visibilityCondition": {
            "type": "object", "additionalProperties": false,
            "required": ["target", "mode", "rules"],
            "properties": {
                "target": {"enum": ["element", "parent"]},
                "mode": {"enum": ["all", "any"]},
                "rules": {"type": "array", "minItems": 1, "maxItems": 25, "items": {"$ref": "#/$defs/conditionRule"}}
            }
        },
        "inlineContent": {
            "type": "array", "maxItems": 1000,
            "items": {"oneOf": [
                {"$ref": "#/$defs/inlineText"},
                {"$ref": "#/$defs/inlineBreak"},
                {"$ref": "#/$defs/inlineVariable"}
            ]}
        },
        "heading": {
            "type": "object", "additionalProperties": false,
            "required": ["id", "type", "content", "level", "keepWithNext"],
            "properties": {
                "id": {"$ref": "#/$defs/stableId"}, "type": {"const": "heading"},
                "content": {"$ref": "#/$defs/inlineContent"},
                "level": {"type": "integer", "minimum": 1, "maximum": 6},
                "keepWithNext": {"type": "boolean"}, "style": {"$ref": "#/$defs/commonStyle"}, "condition": {"$ref": "#/$defs/visibilityCondition"}
            }
        },
        "staticText": {
            "type": "object", "additionalProperties": false,
            "required": ["id", "type", "text"],
            "properties": {
                "id": {"$ref": "#/$defs/stableId"}, "type": {"const": "static-text"},
                "text": {"type": "string", "maxLength": 10000}, "style": {"$ref": "#/$defs/commonStyle"}, "condition": {"$ref": "#/$defs/visibilityCondition"}
            }
        },
        "paragraph": {
            "type": "object", "additionalProperties": false,
            "required": ["id", "type", "content", "alignment"],
            "properties": {
                "id": {"$ref": "#/$defs/stableId"}, "type": {"const": "paragraph"},
                "content": {"$ref": "#/$defs/inlineContent"},
                "alignment": {"enum": ["start", "center", "end", "justify"]}, "style": {"$ref": "#/$defs/commonStyle"}, "condition": {"$ref": "#/$defs/visibilityCondition"}
            }
        },
        "divider": {
            "type": "object", "additionalProperties": false,
            "required": ["id", "type", "orientation", "lineStyle", "color", "thickness", "length"],
            "properties": {
                "id": {"$ref": "#/$defs/stableId"}, "type": {"const": "divider"},
                "orientation": {"enum": ["horizontal", "vertical"]},
                "lineStyle": {"enum": ["solid", "dashed", "dotted", "double"]},
                "color": {"$ref": "#/$defs/color"},
                "thickness": {
                    "type": "object", "additionalProperties": false,
                    "required": ["value", "unit"],
                    "properties": {
                        "value": {"type": "number", "minimum": 0.1, "maximum": 20},
                        "unit": {"const": "mm"}
                    }
                },
                "length": {
                    "type": "object", "additionalProperties": false,
                    "required": ["value", "unit"],
                    "properties": {
                        "value": {"type": "number", "minimum": 1, "maximum": 2000},
                        "unit": {"const": "mm"}
                    }
                }, "style": {"$ref": "#/$defs/commonStyle"}, "condition": {"$ref": "#/$defs/visibilityCondition"}
            }
        },
        "spacer": {
            "type": "object", "additionalProperties": false,
            "required": ["id", "type", "height"],
            "properties": {
                "id": {"$ref": "#/$defs/stableId"}, "type": {"const": "spacer"},
                "height": {
                    "type": "object", "additionalProperties": false,
                    "required": ["value", "unit"],
                    "properties": {
                        "value": {"type": "number", "minimum": 0.1, "maximum": 500},
                        "unit": {"const": "mm"}
                    }
                }, "style": {"$ref": "#/$defs/commonStyle"}, "condition": {"$ref": "#/$defs/visibilityCondition"}
            }
        },
        "pageBreak": {
            "type": "object", "additionalProperties": false,
            "required": ["id", "type"],
            "properties": {
                "id": {"$ref": "#/$defs/stableId"}, "type": {"const": "page-break"}, "style": {"$ref": "#/$defs/commonStyle"}, "condition": {"$ref": "#/$defs/visibilityCondition"}
            }
        },
        "flowElement": {"oneOf": [
            {"$ref": "#/$defs/flowContainer"}, {"$ref": "#/$defs/heading"},
            {"$ref": "#/$defs/staticText"}, {"$ref": "#/$defs/paragraph"},
            {"$ref": "#/$defs/divider"}, {"$ref": "#/$defs/spacer"},
            {"$ref": "#/$defs/pageBreak"}
        ]},
        "flowContainer": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "id", "type", "children", "margin", "padding", "minHeight", "keepTogether"
            ],
            "properties": {
                "id": {"$ref": "#/$defs/stableId"},
                "type": {"const": "flow-container"},
                "children": {
                    "type": "array",
                    "items": {"$ref": "#/$defs/flowElement"}
                },
                "margin": {"$ref": "#/$defs/boxEdges"},
                "padding": {"$ref": "#/$defs/boxEdges"},
                "minHeight": {"$ref": "#/$defs/millimetres"},
                "keepTogether": {"type": "boolean"}, "style": {"$ref": "#/$defs/commonStyle"}, "condition": {"$ref": "#/$defs/visibilityCondition"}
            }
        },
        "flowSection": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "id", "type", "children", "margin", "padding", "minHeight",
                "keepTogether", "startNewPage"
            ],
            "properties": {
                "id": {"$ref": "#/$defs/stableId"},
                "type": {"const": "flow-section"},
                "children": {
                    "type": "array",
                    "items": {"$ref": "#/$defs/flowElement"}
                },
                "margin": {"$ref": "#/$defs/boxEdges"},
                "padding": {"$ref": "#/$defs/boxEdges"},
                "minHeight": {"$ref": "#/$defs/millimetres"},
                "keepTogether": {"type": "boolean"},
                "startNewPage": {"type": "boolean"}, "style": {"$ref": "#/$defs/commonStyle"}, "condition": {"$ref": "#/$defs/visibilityCondition"}
            }
        },
        "page": {
            "type": "object",
            "additionalProperties": false,
            "required": ["size", "orientation", "margins"],
            "properties": {
                "size": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_-]{0,63}$"},
                "orientation": {"enum": ["portrait", "landscape"]},
                "margins": {"$ref": "#/$defs/boxEdges"}
            }
        },
        "documentDefaults": {
            "type": "object",
            "additionalProperties": false,
            "required": ["fontFamily", "fontSize", "color", "lineHeight", "locale", "timezone"],
            "properties": {
                "fontFamily": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 100,
                    "pattern": "^[A-Za-z][A-Za-z0-9 ._-]*$"
                },
                "fontSize": {"$ref": "#/$defs/points"},
                "color": {"$ref": "#/$defs/color"},
                "lineHeight": {"type": "number", "minimum": 0.5, "maximum": 5},
                "locale": {"type": "string", "pattern": "^[a-z]{2}_[A-Z]{2}$"},
                "timezone": {
                    "type": "string",
                    "pattern": "^(UTC|[A-Za-z_]+(?:/[A-Za-z0-9_+.-]+)+)$"
                }
            }
        },
        "document": {
            "type": "object",
            "additionalProperties": false,
            "required": ["page", "defaults", "titlePattern", "filenamePattern"],
            "properties": {
                "page": {"$ref": "#/$defs/page"},
                "defaults": {"$ref": "#/$defs/documentDefaults"},
                "titlePattern": {"type": "string", "maxLength": 255},
                "filenamePattern": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 255,
                    "pattern": "^[^/\\\\\\u0000-\\u001F]+$"
                },
                "style": {"$ref": "#/$defs/commonStyle"}
            }
        },
        "noSourceDescriptor": {
            "type": "object",
            "additionalProperties": false,
            "required": ["type"],
            "properties": {
                "type": {"const": "none"}
            }
        },
        "entitySourceDescriptor": {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "entityType", "relationshipDepth"],
            "properties": {
                "type": {"const": "entity"},
                "entityType": {
                    "type": "string",
                    "pattern": "^[A-Za-z][A-Za-z0-9]{0,99}$"
                },
                "relationshipDepth": {"type": "integer", "minimum": 1, "maximum": 3}
            }
        },
        "spreadsheetSourceDescriptor": {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "format"],
            "properties": {
                "type": {"const": "spreadsheet"},
                "format": {"enum": ["csv", "xlsx"]},
                "worksheet": {"type": "string", "minLength": 1, "maxLength": 100}
            },
            "allOf": [
                {
                    "if": {"properties": {"format": {"const": "csv"}}},
                    "then": {"not": {"required": ["worksheet"]}}
                }
            ]
        },
        "sourceDescriptor": {
            "oneOf": [
                {"$ref": "#/$defs/noSourceDescriptor"},
                {"$ref": "#/$defs/entitySourceDescriptor"},
                {"$ref": "#/$defs/spreadsheetSourceDescriptor"}
            ]
        }
    }
}
