    "fields": {
        "name": {"type": "varchar", "maxLength": 249, "required": true},
        "billingAddress": {"type": "address"},
        "billingAddressStreet": {"type": "text", "maxLength": 255, "dbType": "varchar"},
        "billingAddressCity": {"type": "varchar"},
